# ── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── MySQL Connection ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword

# ── Database Names ───────────────────────────────────────────────────────────
# Central database (organizations, units registry, super admin, global audit)
DB_CENTRAL_NAME=vms_central
# Legacy fallback (kept for backward compatibility — maps to central internally)
DB_NAME=vms_central

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=24h

# ── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="VMS System" <your@gmail.com>

# ── App Meta ─────────────────────────────────────────────────────────────────
APP_NAME=VMS

# ── Unit DB Prefix ───────────────────────────────────────────────────────────
# Unit DBs are named as: <prefix><unit_code_lowercase>
# Example: vms_unit_ + hq = vms_unit_hq
UNIT_DB_PREFIX=vms_unit_
